{%- comment -%}Seven Meridian Contact Form{%- endcomment -%}

<style>
  .contact-section {
    max-width: 720px;
    margin: 0 auto;
    padding: 60px 24px 80px;
  }
  .contact-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .contact-header h1 {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 40px);
    color: var(--color-primary);
    margin: 0 0 12px;
  }
  .contact-header p {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-text-light);
    max-width: 480px;
    margin: 0 auto;
  }
  .contact-info-bar {
    display: flex;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
    margin-bottom: 40px;
    padding: 20px;
    background: #F8F7F4;
    border-radius: 8px;
  }
  .contact-info-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--color-primary);
  }
  .contact-info-item svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 1.5;
    flex-shrink: 0;
  }
  .contact-info-item a {
    color: var(--color-primary);
    text-decoration: none;
  }
  .contact-info-item a:hover {
    color: var(--color-accent);
  }
  .contact-form {
    display: grid;
    gap: 20px;
  }
  .contact-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  @media (max-width: 560px) {
    .contact-form__row { grid-template-columns: 1fr; }
  }
  .contact-form label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 6px;
    letter-spacing: 0.03em;
  }
  .contact-form input,
  .contact-form textarea,
  .contact-form select {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 14px;
    color: var(--color-text);
    background: #fff;
    font-family: inherit;
    transition: border-color 0.2s;
  }
  .contact-form input:focus,
  .contact-form textarea:focus,
  .contact-form select:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .contact-form textarea {
    min-height: 140px;
    resize: vertical;
  }
  .contact-form__submit {
    display: inline-block;
    padding: 16px 40px;
    background: var(--color-primary);
    color: #fff;
    border: none;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 4px;
    transition: opacity 0.2s;
  }
  .contact-form__submit:hover { opacity: 0.9; }
  .contact-form__note {
    font-size: 12px;
    color: var(--color-text-light);
    text-align: center;
    margin-top: 8px;
  }
</style>

<section class="contact-section">
  <div class="contact-header">
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subheading }}</p>
  </div>

  <div class="contact-info-bar">
    <div class="contact-info-item">
      <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
    </div>
    <div class="contact-info-item">
      <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
      <span>{{ section.settings.location }}</span>
    </div>
  </div>

  {%- form 'contact' -%}
    {%- if form.posted_successfully? -%}
      <div style="background: #f0fdf4; border: 1px solid #86efac; border-radius: 8px; padding: 20px; text-align: center; margin-bottom: 24px;">
        <p style="color: #166534; font-weight: 600; margin: 0;">Thank you for reaching out! We'll get back to you within 24 hours.</p>
      </div>
    {%- endif -%}

    {%- if form.errors -%}
      <div style="background: #fef2f2; border: 1px solid #fca5a5; border-radius: 8px; padding: 20px; margin-bottom: 24px;">
        {{ form.errors | default_errors }}
      </div>
    {%- endif -%}

    <div class="contact-form">
      <div class="contact-form__row">
        <div>
          <label for="contact-name">Name *</label>
          <input type="text" id="contact-name" name="contact[name]" placeholder="Your full name" required>
        </div>
        <div>
          <label for="contact-email">Email *</label>
          <input type="email" id="contact-email" name="contact[email]" placeholder="you@example.com" required>
        </div>
      </div>

      <div>
        <label for="contact-subject">Subject</label>
        <select id="contact-subject" name="contact[subject]">
          <option value="General Inquiry">General Inquiry</option>
          <option value="Order Question">Order Question</option>
          <option value="Subscription Help">Subscription Help</option>
          <option value="Return / Refund">Return / Refund</option>
          <option value="Wholesale Inquiry">Wholesale Inquiry</option>
          <option value="Other">Other</option>
        </select>
      </div>

      <div>
        <label for="contact-message">Message *</label>
        <textarea id="contact-message" name="contact[body]" placeholder="How can we help?" required></textarea>
      </div>

      <div style="text-align: center;">
        <button type="submit" class="contact-form__submit">Send Message</button>
        <p class="contact-form__note">We typically respond within 24 hours · US-based support</p>
      </div>
    </div>
  {%- endform -%}
</section>

{% schema %}
{
  "name": "Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get in Touch"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Have a question about our botanical relief oil, your subscription, or an order? We're here to help."
    },
    {
      "type": "text",
      "id": "email",
      "label": "Contact email",
      "default": "support@sevenmeridian.com"
    },
    {
      "type": "text",
      "id": "location",
      "label": "Location",
      "default": "Sunrise, FL · United States"
    }
  ],
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}
