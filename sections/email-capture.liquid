<style>
  .email-capture {
    padding: 64px 24px;
    background: var(--color-background);
    text-align: center;
  }
  .email-capture__inner {
    max-width: 520px;
    margin: 0 auto;
  }
  .email-capture__title {
    font-family: var(--font-heading);
    font-size: clamp(24px, 3vw, 32px);
    color: var(--color-primary);
    margin: 0 0 8px;
  }
  .email-capture__desc {
    font-size: 15px;
    color: var(--color-text-light);
    margin: 0 0 24px;
  }
  .email-capture__form {
    display: flex;
    gap: 8px;
  }
  .email-capture__form input[type="email"] {
    flex: 1;
    padding: 14px 16px;
    border: 1px solid var(--color-border);
    font-size: 14px;
    background: #fff;
  }
  .email-capture__form button {
    padding: 14px 24px;
    background: var(--color-primary);
    color: #fff;
    border: none;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
  }
  @media (max-width: 480px) {
    .email-capture__form { flex-direction: column; }
  }
</style>

<section class="email-capture">
  <div class="email-capture__inner">
    <h2 class="email-capture__title">{{ section.settings.heading }}</h2>
    <p class="email-capture__desc">{{ section.settings.description }}</p>
    {% form 'customer', id: 'email-capture' %}
      <div class="email-capture__form">
        <input type="email" name="contact[email]" placeholder="Enter your email" aria-label="Email address" required>
        <input type="hidden" name="contact[tags]" value="newsletter">
        <button type="submit">{{ section.settings.button_text }}</button>
      </div>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Email Capture",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join the Seven Meridian Community" },
    { "type": "text", "id": "description", "label": "Description", "default": "Get 10% off your first order, plus tips on botanical wellness and early access to new products." },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Get 10% Off" }
  ],
  "presets": [{ "name": "Email Capture" }]
}
{% endschema %}
