<style>
  .featured-product {
    padding: 80px 24px;
    background: var(--color-background);
  }
  .featured-product__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .featured-product__image {
    position: relative;
  }
  .featured-product__image img {
    width: 100%;
    height: auto;
    border-radius: 4px;
  }
  .featured-product__ribbon {
    position: absolute;
    top: 16px;
    left: -8px;
    background: var(--color-accent);
    color: var(--color-primary);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 16px 6px 12px;
    z-index: 2;
  }
  .featured-product__ribbon::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -8px;
    border: 4px solid transparent;
    border-top-color: #8a7340;
    border-right-color: #8a7340;
  }
  .featured-product__content {}
  .featured-product__tag {
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 12px;
  }
  .featured-product__title {
    font-family: var(--font-heading);
    font-size: clamp(24px, 3.5vw, 36px);
    color: var(--color-primary);
    margin: 0 0 16px;
  }
  .featured-product__price {
    font-size: 24px;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 4px;
  }
  .featured-product__sub-price {
    font-size: 14px;
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: 20px;
  }
  .featured-product__bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
  }
  .featured-product__bullets li {
    padding: 6px 0 6px 24px;
    position: relative;
    font-size: 14px;
    color: var(--color-text);
    line-height: 1.6;
  }
  .featured-product__bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 13px;
    width: 8px;
    height: 8px;
    background: var(--color-accent);
    border-radius: 50%;
  }
  .featured-product__stars {
    color: var(--color-accent);
    font-size: 16px;
    letter-spacing: 2px;
    margin-bottom: 16px;
  }
  .featured-product__stars span {
    font-size: 12px;
    color: var(--color-text);
    letter-spacing: 0;
    margin-left: 6px;
  }
  .featured-product__actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .featured-product__urgency {
    margin-top: 10px;
    font-size: 12px;
    color: #b45309;
    font-weight: 600;
  }
  .featured-product__mini-trust {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid var(--color-border);
  }
  .featured-product__mini-trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0.03em;
  }
  .featured-product__mini-trust-item svg {
    width: 16px;
    height: 16px;
    color: var(--color-accent);
    flex-shrink: 0;
  }
  @media (max-width: 768px) {
    .featured-product__inner { grid-template-columns: 1fr; }
  }
</style>

<section class="featured-product">
  <div class="featured-product__inner">
    <div class="featured-product__image">
      <div class="featured-product__ribbon">Best Seller</div>
      {%- if section.settings.product != blank and section.settings.product.featured_image != blank -%}
        {{ section.settings.product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy' }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
    <div class="featured-product__content">
      <p class="featured-product__tag">{{ section.settings.tag_text }}</p>
      {%- if section.settings.product != blank -%}
        <h2 class="featured-product__title">{{ section.settings.product.title }}</h2>
        <div class="featured-product__price">{{ section.settings.product.price | money }}</div>
        <div class="featured-product__sub-price">{{ section.settings.subscribe_text }}</div>
      {%- else -%}
        <h2 class="featured-product__title">Botanical Relief Oil — 10ml</h2>
        <div class="featured-product__price">$24.99</div>
        <div class="featured-product__sub-price">$21.24 with Subscribe & Save (15% off)</div>
      {%- endif -%}
      <div class="featured-product__stars">&#9733;&#9733;&#9733;&#9733;&#9733; <span>4.9 / 5 — heritage oil users</span></div>
      <ul class="featured-product__bullets">
        {%- for block in section.blocks -%}
          <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
        {%- endfor -%}
      </ul>
      <div class="featured-product__actions">
        {%- if section.settings.product != blank -%}
          {%- assign fp_variant = section.settings.product.selected_or_first_available_variant -%}
          <form action="/cart/add" method="post">
            <input type="hidden" name="id" value="{{ fp_variant.id }}">
            <input type="hidden" name="quantity" value="1">
            <button type="submit" class="btn-primary">Add to Cart — {{ section.settings.product.price | money }}</button>
          </form>
          <a href="{{ section.settings.product.url }}" class="btn-secondary">View Details</a>
        {%- else -%}
          <a href="/collections/all" class="btn-primary">Shop Now</a>
        {%- endif -%}
        <a href="/pages/subscribe" class="btn-secondary">Subscribe &amp; Save</a>
      </div>
      <p class="featured-product__urgency">&#9202; Ships same day if ordered before 2pm EST</p>
      <div class="featured-product__mini-trust">
        <div class="featured-product__mini-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          Free Shipping
        </div>
        <div class="featured-product__mini-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
          90-Day Guarantee
        </div>
        <div class="featured-product__mini-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Made in USA
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Product",
  "settings": [
    { "type": "product", "id": "product", "label": "Product" },
    { "type": "text", "id": "tag_text", "label": "Tag text", "default": "HERO PRODUCT · BEST SELLER" },
    { "type": "text", "id": "subscribe_text", "label": "Subscription price text", "default": "$19.54 with Subscribe & Save (15% off)" }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Bullet point",
      "settings": [
        { "type": "text", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Product",
      "blocks": [
        { "type": "bullet", "settings": { "text": "22% menthol for fast cooling action" } },
        { "type": "bullet", "settings": { "text": "7 botanical oils at full heritage concentration" } },
        { "type": "bullet", "settings": { "text": "Aluminum cap with Polycone liner — sealed against evaporation" } },
        { "type": "bullet", "settings": { "text": "COA-tested every batch · Made in USA" } },
        { "type": "bullet", "settings": { "text": "90-day satisfaction guarantee" } }
      ]
    }
  ]
}
{% endschema %}
