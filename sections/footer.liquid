{%- comment -%}Seven Meridian Footer{%- endcomment -%}

<style>
  .site-footer {
    background: var(--color-primary);
    color: #fff;
    padding: 64px 0 24px;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    margin-bottom: 48px;
  }
  .footer-col h4 {
    font-family: var(--font-heading);
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin: 0 0 16px;
  }
  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-col li {
    margin-bottom: 8px;
  }
  .footer-col a {
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    font-size: 14px;
    transition: color 0.2s;
  }
  .footer-col a:hover {
    color: var(--color-accent);
  }
  .footer-email-form {
    margin-top: 16px;
  }
  .footer-email-form input[type="email"] {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid rgba(255,255,255,0.3);
    background: transparent;
    color: #fff;
    font-size: 14px;
    margin-bottom: 8px;
  }
  .footer-email-form input[type="email"]::placeholder {
    color: rgba(255,255,255,0.5);
  }
  .footer-email-form button {
    width: 100%;
    padding: 10px 12px;
    background: var(--color-accent);
    color: var(--color-primary);
    border: none;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .footer-email-form button:hover {
    opacity: 0.9;
  }
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.15);
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 12px;
    color: rgba(255,255,255,0.5);
  }
  .footer-bottom a {
    color: rgba(255,255,255,0.5);
    text-decoration: none;
  }
  .footer-bottom a:hover {
    color: var(--color-accent);
  }
  .footer-legal {
    display: flex;
    gap: 16px;
  }
  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>

<footer class="site-footer" role="contentinfo">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-col">
        <h4>Shop</h4>
        <ul>
          <li><a href="/collections/all">All Products</a></li>
          <li><a href="/products/botanical-relief-oil-10ml">Botanical Relief Oil</a></li>
          <li><a href="/pages/subscribe">Subscribe &amp; Save</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Learn</h4>
        <ul>
          <li><a href="/pages/our-formula">Our Formula</a></li>
          <li><a href="/pages/how-to-use">How to Use</a></li>
          <li><a href="/blogs/journal">Journal</a></li>
          <li><a href="/pages/our-story">Our Story</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Support</h4>
        <ul>
          <li><a href="/pages/faq">FAQ</a></li>
          <li><a href="/pages/contact">Contact Us</a></li>
          <li><a href="/pages/shipping-returns">Shipping &amp; Returns</a></li>
          <li><a href="/pages/guarantee">90-Day Guarantee</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Stay Connected</h4>
        {%- if settings.social_instagram != blank -%}
          <ul>
            <li><a href="{{ settings.social_instagram }}" target="_blank" rel="noopener">Instagram</a></li>
            {%- if settings.social_tiktok != blank -%}
              <li><a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener">TikTok</a></li>
            {%- endif -%}
          </ul>
        {%- endif -%}
        <div class="footer-email-form">
          {% form 'customer', id: 'footer-email' %}
            <input type="email" name="contact[email]" placeholder="Your email address" aria-label="Email address" required>
            <input type="hidden" name="contact[tags]" value="newsletter">
            <button type="submit">Join &amp; Get 10% Off</button>
          {% endform %}
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} Seven Meridian &middot; AT USA Investments LLC &middot; Sunrise, FL 33323</span>
      <div class="footer-legal">
        <a href="/policies/privacy-policy">Privacy Policy</a>
        <a href="/policies/terms-of-service">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
