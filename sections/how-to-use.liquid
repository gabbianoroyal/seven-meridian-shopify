<style>
  .how-to-use {
    padding: 80px 24px;
    background: var(--color-background);
  }
  .how-to-use__inner {
    max-width: 1000px;
    margin: 0 auto;
  }
  .how-to-use__title {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 40px);
    color: var(--color-primary);
    text-align: center;
    margin: 0 0 12px;
  }
  .how-to-use__subtitle {
    text-align: center;
    color: var(--color-text-light);
    font-size: 16px;
    margin: 0 0 48px;
  }
  .use-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .use-card {
    border: 1px solid var(--color-border);
    padding: 32px;
    background: #fff;
  }
  .use-card__number {
    font-family: var(--font-heading);
    font-size: 36px;
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: 12px;
  }
  .use-card__name {
    font-weight: 700;
    font-size: 16px;
    color: var(--color-primary);
    margin-bottom: 8px;
  }
  .use-card__desc {
    font-size: 14px;
    color: var(--color-text-light);
    line-height: 1.65;
  }
  @media (max-width: 600px) {
    .use-grid { grid-template-columns: 1fr; }
  }
</style>

<section class="how-to-use">
  <div class="how-to-use__inner">
    <h2 class="how-to-use__title">{{ section.settings.heading }}</h2>
    <p class="how-to-use__subtitle">{{ section.settings.subheading }}</p>
    <div class="use-grid">
      {%- for block in section.blocks -%}
        <div class="use-card" {{ block.shopify_attributes }}>
          <div class="use-card__number">{{ forloop.index }}</div>
          <div class="use-card__name">{{ block.settings.title }}</div>
          <div class="use-card__desc">{{ block.settings.description }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How to Use",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "4 Uses, One Bottle" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Apply 1–4 drops to the desired area and rub in gently." }
  ],
  "blocks": [
    {
      "type": "use_case",
      "name": "Use Case",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [
    {
      "name": "How to Use",
      "blocks": [
        { "type": "use_case", "settings": { "title": "Sore Muscles", "description": "After workouts: 2–3 drops to sore muscles. Rub in for fast-cooling relief that lasts 4+ hours." } },
        { "type": "use_case", "settings": { "title": "Tension Headaches", "description": "For tension: 1 drop, diluted with carrier oil, to the temples. Take a deep breath. Let the eucalyptus and lavender do their work." } },
        { "type": "use_case", "settings": { "title": "Sinus Support", "description": "For congestion: 1 drop under the nose or on the chest. Eucalyptus and wintergreen support clear breathing." } },
        { "type": "use_case", "settings": { "title": "Joint Comfort", "description": "For stiff joints: 3–4 drops massaged into the area twice daily. The warming sensation supports ongoing comfort." } }
      ]
    }
  ]
}
{% endschema %}
