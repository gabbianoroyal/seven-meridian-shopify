<style>
  .how-to-use {
    padding: 80px 24px;
    background: var(--color-background);
  }
  .how-to-use__inner {
    max-width: 1000px;
    margin: 0 auto;
  }
  .how-to-use__title {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 40px);
    color: var(--color-primary);
    text-align: center;
    margin: 0 0 12px;
  }
  .how-to-use__subtitle {
    text-align: center;
    color: var(--color-text-light);
    font-size: 16px;
    margin: 0 0 48px;
  }
  .use-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .use-card {
    border: 1px solid var(--color-border);
    padding: 32px;
    background: #fff;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .use-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(11, 37, 69, 0.08);
  }
  .use-card__icon {
    width: 48px;
    height: 48px;
    margin-bottom: 12px;
    color: var(--color-accent);
  }
  .use-card__number {
    font-family: var(--font-heading);
    font-size: 36px;
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: 12px;
  }
  .how-to-use__cta {
    text-align: center;
    margin-top: 48px;
  }
  .use-card__name {
    font-weight: 700;
    font-size: 16px;
    color: var(--color-primary);
    margin-bottom: 8px;
  }
  .use-card__desc {
    font-size: 14px;
    color: var(--color-text-light);
    line-height: 1.65;
  }
  @media (max-width: 600px) {
    .use-grid { grid-template-columns: 1fr; }
  }
</style>

<section class="how-to-use">
  <div class="how-to-use__inner">
    <h2 class="how-to-use__title">{{ section.settings.heading }}</h2>
    <p class="how-to-use__subtitle">{{ section.settings.subheading }}</p>
    <div class="use-grid">
      {%- for block in section.blocks -%}
        <div class="use-card" {{ block.shopify_attributes }}>
          {%- case forloop.index -%}
            {%- when 1 -%}
              <svg class="use-card__icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 38c-2-3-4-8-4-14 0-8 6-14 14-14s14 6 14 14c0 6-2 11-4 14"/><path d="M18 26c0-3 2.7-6 6-6s6 3 6 6"/><line x1="24" y1="20" x2="24" y2="14"/><line x1="18" y1="22" x2="15" y2="18"/><line x1="30" y1="22" x2="33" y2="18"/></svg>
            {%- when 2 -%}
              <svg class="use-card__icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="24" cy="20" r="12"/><path d="M16 18c2-4 5-6 8-6s6 2 8 6"/><path d="M18 36h12"/><path d="M20 36v4"/><path d="M28 36v4"/></svg>
            {%- when 3 -%}
              <svg class="use-card__icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M24 40c-6 0-10-4-10-10V18c0-6 4-10 10-10s10 4 10 10v12c0 6-4 10-10 10z"/><path d="M20 22c0 0 2 2 4 2s4-2 4-2"/><path d="M10 28h4"/><path d="M34 28h4"/></svg>
            {%- when 4 -%}
              <svg class="use-card__icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="24" cy="24" r="4"/><path d="M24 10v10"/><path d="M24 28v10"/><path d="M10 24h10"/><path d="M28 24h10"/><circle cx="24" cy="24" r="14"/></svg>
          {%- endcase -%}
          <div class="use-card__number">{{ forloop.index }}</div>
          <div class="use-card__name">{{ block.settings.title }}</div>
          <div class="use-card__desc">{{ block.settings.description }}</div>
        </div>
      {%- endfor -%}
    </div>
    <div class="how-to-use__cta">
      <a href="/collections/all" class="btn-primary">Experience all four benefits &rarr; Shop Now</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How to Use",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "4 Uses, One Bottle" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Apply 1–4 drops to the desired area and rub in gently." }
  ],
  "blocks": [
    {
      "type": "use_case",
      "name": "Use Case",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [
    {
      "name": "How to Use",
      "blocks": [
        { "type": "use_case", "settings": { "title": "Sore Muscles", "description": "After workouts: 2–3 drops to sore muscles. Rub in for fast-cooling relief that lasts 4+ hours." } },
        { "type": "use_case", "settings": { "title": "Tension Headaches", "description": "For tension: 1 drop, diluted with carrier oil, to the temples. Take a deep breath. Let the eucalyptus and lavender do their work." } },
        { "type": "use_case", "settings": { "title": "Sinus Support", "description": "For congestion: 1 drop under the nose or on the chest. Eucalyptus and wintergreen support clear breathing." } },
        { "type": "use_case", "settings": { "title": "Joint Comfort", "description": "For stiff joints: 3–4 drops massaged into the area twice daily. The warming sensation supports ongoing comfort." } }
      ]
    }
  ]
}
{% endschema %}
