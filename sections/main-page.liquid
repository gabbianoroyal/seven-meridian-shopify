<style>
  .page-content {
    max-width: 760px;
    margin: 0 auto;
    padding: 48px 24px;
  }
  .page-content h1 {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 40px);
    color: var(--color-primary);
    margin: 0 0 24px;
  }
  .page-content .rte {
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-text);
  }
  .page-content .rte h2, .page-content .rte h3 {
    font-family: var(--font-heading);
    color: var(--color-primary);
    margin-top: 32px;
  }
</style>

<section class="page-content">
  <h1>{{ page.title }}</h1>
  <div class="rte">{{ page.content }}</div>
</section>

{% schema %}
{ "name": "Page Content", "settings": [] }
{% endschema %}
