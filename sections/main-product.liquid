<style>
  .product-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }
  .product-gallery {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .product-gallery__main {
    aspect-ratio: 1;
    background: #F8F7F4;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }
  .product-gallery__main img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .product-gallery__thumbs {
    display: flex;
    gap: 8px;
    overflow-x: auto;
  }
  .product-gallery__thumb {
    width: 72px;
    height: 72px;
    border: 1px solid var(--color-border);
    cursor: pointer;
    flex-shrink: 0;
    background: #F8F7F4;
  }
  .product-gallery__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .product-info {}
  .product-info__breadcrumb {
    font-size: 12px;
    color: var(--color-text-light);
    margin-bottom: 16px;
  }
  .product-info__breadcrumb a {
    color: var(--color-text-light);
    text-decoration: none;
  }
  .product-info__breadcrumb a:hover { color: var(--color-accent); }
  .product-info__title {
    font-family: var(--font-heading);
    font-size: clamp(24px, 3vw, 32px);
    color: var(--color-primary);
    margin: 0 0 8px;
  }
  .product-info__price-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 20px;
  }
  .product-info__price {
    font-size: 24px;
    font-weight: 700;
    color: var(--color-primary);
  }
  .product-info__sub-price {
    font-size: 14px;
    color: var(--color-accent);
    font-weight: 600;
  }
  .product-info__form {
    margin-bottom: 32px;
  }
  .product-info__quantity {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }
  .product-info__quantity label {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .product-info__quantity input {
    width: 60px;
    text-align: center;
    padding: 8px;
    border: 1px solid var(--color-border);
    font-size: 14px;
  }
  .add-to-cart-btn {
    width: 100%;
    padding: 16px;
    background: var(--color-primary);
    color: #fff;
    border: none;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s;
  }
  .add-to-cart-btn:hover { background: #0d2d52; }
  .add-to-cart-btn:disabled {
    background: var(--color-text-light);
    cursor: not-allowed;
  }
  .product-info__accordion {
    border-top: 1px solid var(--color-border);
    margin-top: 24px;
  }
  .product-info__accordion details {
    border-bottom: 1px solid var(--color-border);
  }
  .product-info__accordion summary {
    padding: 16px 0;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--color-primary);
  }
  .product-info__accordion summary::-webkit-details-marker { display: none; }
  .product-info__accordion summary::after {
    content: '+';
    font-size: 18px;
    color: var(--color-accent);
  }
  .product-info__accordion details[open] summary::after { content: '−'; }
  .product-info__accordion .accordion-content {
    padding: 0 0 16px;
    font-size: 14px;
    color: var(--color-text-light);
    line-height: 1.7;
  }
  .product-info__stars {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }
  .product-info__stars svg { width: 18px; height: 18px; fill: #C8963E; }
  .product-info__stars span {
    font-size: 13px;
    color: var(--color-text-light);
    font-weight: 500;
  }
  .product-info__urgency {
    font-size: 13px;
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .product-info__urgency svg { width: 14px; height: 14px; fill: var(--color-accent); }
  /* Native Subscription App widget container */
  .subscriptions_app_embed_block { margin-bottom: 16px; }
  .trust-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 16px;
    margin-bottom: 24px;
  }
  .trust-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .trust-badge svg { width: 18px; height: 18px; fill: var(--color-accent); flex-shrink: 0; }
  .cross-sell {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }
  .cross-sell__title {
    font-family: var(--font-heading);
    font-size: 16px;
    color: var(--color-primary);
    margin: 0 0 16px;
  }
  .cross-sell__placeholder {
    background: #F8F7F4;
    border: 1px dashed var(--color-border);
    padding: 32px;
    text-align: center;
    font-size: 13px;
    color: var(--color-text-light);
    border-radius: 4px;
  }
  /* Sticky ATC bar */
  .sticky-atc-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: #fff;
    border-top: 1px solid var(--color-border);
    padding: 12px 24px;
    z-index: 900;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    transform: translateY(100%);
    transition: transform 0.3s ease;
    box-shadow: 0 -2px 12px rgba(0,0,0,0.08);
  }
  .sticky-atc-bar.is-visible { transform: translateY(0); }
  .sticky-atc-bar__info {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-primary);
    white-space: nowrap;
  }
  .sticky-atc-bar__btn {
    padding: 12px 32px;
    background: var(--color-primary);
    color: #fff;
    border: none;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    flex-shrink: 0;
  }
  .sticky-atc-bar__btn:hover { background: #0d2d52; }
  @media (min-width: 769px) {
    .sticky-atc-bar { display: none; }
  }
  @media (max-width: 768px) {
    .product-page { grid-template-columns: 1fr; }
  }
</style>

{%- assign current_variant = product.selected_or_first_available_variant -%}

<section class="product-page">
  <div class="product-gallery">
    <div class="product-gallery__main">
      {%- if product.featured_image -%}
        {{ product.featured_image | image_url: width: 1000 | image_tag: loading: 'eager', id: 'product-main-image', alt: product.title }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag }}
      {%- endif -%}
    </div>
    {%- if product.images.size > 1 -%}
      <div class="product-gallery__thumbs">
        {%- for image in product.images -%}
          <div class="product-gallery__thumb" data-image-url="{{ image | image_url: width: 1000 }}">
            {{ image | image_url: width: 150 | image_tag: loading: 'lazy', alt: product.title }}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <div class="product-info">
    <nav class="product-info__breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a> /
      {%- if product.collections.size > 0 -%}
        <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a> /
      {%- endif -%}
      {{ product.title }}
    </nav>

    <h1 class="product-info__title">{{ product.title }}</h1>

    <div class="product-info__stars">
      {% for i in (1..5) %}<svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.27 5.82 22 7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>{% endfor %}
      <span>from heritage oil users</span>
    </div>

    <div class="product-info__urgency">
      <svg viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>
      Ships same day &middot; Order within <span id="urgency-countdown"></span>
    </div>

    <div class="product-info__price-row">
      <span class="product-info__price">{{ current_variant.price | money }}</span>
      {%- if product.selling_plan_groups.size > 0 -%}
        <span class="product-info__sub-price">Subscribe &amp; save 15%</span>
      {%- endif -%}
    </div>

    {%- form 'product', product -%}
      <div class="product-info__form">
        <input type="hidden" name="id" value="{{ current_variant.id }}">

        <!-- Native Subscription App Widget -->
        <div class="subscriptions_app_embed_block"></div>

        <div class="product-info__quantity">
          <label for="quantity">Qty</label>
          <input type="number" id="quantity" name="quantity" value="1" min="1" max="10">
        </div>
        <button type="submit" class="add-to-cart-btn" id="main-atc-btn" {% unless current_variant.available %}disabled{% endunless %}>
          {%- if current_variant.available -%}
            Add to Cart — {{ current_variant.price | money }}
          {%- else -%}
            Sold Out
          {%- endif -%}
        </button>

        <!-- Trust Badges -->
        <div class="trust-badges">
          <div class="trust-badge">
            <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 2a2.5 2.5 0 010 5 2.5 2.5 0 010-5z"/></svg>
            Made in USA
          </div>
          <div class="trust-badge">
            <svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
            COA Tested
          </div>
          <div class="trust-badge">
            <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            90-Day Guarantee
          </div>
          <div class="trust-badge">
            <svg viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM12 3c1.66 0 3 1.34 3 3v2H9V6c0-1.66 1.34-3 3-3zm0 14c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z"/></svg>
            Free Shipping on Subs
          </div>
        </div>
      </div>
    {%- endform -%}

    <div class="product-info__accordion">
      {%- if product.description != blank -%}
        <details open>
          <summary>Description</summary>
          <div class="accordion-content">{{ product.description }}</div>
        </details>
      {%- endif -%}
      <details>
        <summary>Ingredients</summary>
        <div class="accordion-content">
          Safflower seed oil (Carthamus tinctorius), menthol, eucalyptus oil (Eucalyptus globulus), camphor, wintergreen oil (Gaultheria procumbens), lavender flower oil (Lavandula angustifolia), clove bud oil (Syzygium aromaticum), tocopherol (vitamin E).
        </div>
      </details>
      <details>
        <summary>How to Use</summary>
        <div class="accordion-content">
          Apply 1–4 drops to desired area and rub in. For temples, neck, or sinuses, dilute with carrier oil. Up to 4x daily. Patch-test first.
        </div>
      </details>
      <details>
        <summary>Shipping &amp; Returns</summary>
        <div class="accordion-content">
          Free shipping on subscriptions. Standard shipping 3–5 business days. 90-day satisfaction guarantee — full refund, no questions asked.
        </div>
      </details>
    </div>

    <!-- Cross-sell placeholder -->
    <div class="cross-sell">
      <h3 class="cross-sell__title">Complete Your Routine</h3>
      <div class="cross-sell__placeholder">Cross-sell products will appear here</div>
    </div>
  </div>
</section>

<!-- Sticky Add to Cart bar (mobile) -->
<div class="sticky-atc-bar" id="sticky-atc-bar">
  <span class="sticky-atc-bar__info">{{ product.title }} — {{ current_variant.price | money }}</span>
  <button class="sticky-atc-bar__btn" onclick="document.getElementById('main-atc-btn').click()">Add to Cart</button>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Thumbnail gallery
  document.querySelectorAll('.product-gallery__thumb').forEach(function(thumb) {
    thumb.addEventListener('click', function() {
      var mainImg = document.getElementById('product-main-image');
      if (mainImg) mainImg.src = this.dataset.imageUrl;
    });
  });

  // Sticky ATC bar — show when main button scrolls out of view
  var mainBtn = document.getElementById('main-atc-btn');
  var stickyBar = document.getElementById('sticky-atc-bar');
  if (mainBtn && stickyBar) {
    var observer = new IntersectionObserver(function(entries) {
      stickyBar.classList.toggle('is-visible', !entries[0].isIntersecting);
    }, { threshold: 0 });
    observer.observe(mainBtn);
  }

  // Urgency countdown — hours until 3 PM cutoff
  var countdownEl = document.getElementById('urgency-countdown');
  if (countdownEl) {
    function updateCountdown() {
      var now = new Date();
      var cutoff = new Date();
      cutoff.setHours(15, 0, 0, 0);
      if (now >= cutoff) { cutoff.setDate(cutoff.getDate() + 1); }
      var diff = cutoff - now;
      var h = Math.floor(diff / 3600000);
      var m = Math.floor((diff % 3600000) / 60000);
      countdownEl.textContent = h + 'h ' + m + 'm';
    }
    updateCountdown();
    setInterval(updateCountdown, 60000);
  }
});
</script>

{% schema %}
{
  "name": "Product Page",
  "settings": []
}
{% endschema %}
