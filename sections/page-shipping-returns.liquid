{%- comment -%}Seven Meridian — Shipping & Returns Page{%- endcomment -%}

<style>
  .shipping-page { max-width: 800px; margin: 0 auto; padding: 60px 24px 80px; }
  .shipping-hero { text-align: center; margin-bottom: 48px; }
  .shipping-hero h1 {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 44px);
    color: var(--color-primary);
    margin: 0 0 12px;
  }
  .shipping-hero p { font-size: 16px; color: var(--color-text-light); max-width: 520px; margin: 0 auto; }

  .shipping-section { margin-bottom: 48px; }
  .shipping-section h2 {
    font-family: var(--font-heading);
    font-size: 24px;
    color: var(--color-primary);
    margin: 0 0 20px;
  }

  .shipping-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 16px;
  }
  .shipping-table th {
    text-align: left;
    padding: 12px 16px;
    background: var(--color-primary);
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
  }
  .shipping-table th:first-child { border-radius: 6px 0 0 0; }
  .shipping-table th:last-child { border-radius: 0 6px 0 0; }
  .shipping-table td {
    padding: 14px 16px;
    font-size: 14px;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
  }
  .shipping-table tr:nth-child(even) td { background: #F8F7F4; }
  .shipping-note { font-size: 13px; color: var(--color-text-light); font-style: italic; }

  .shipping-info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 16px;
  }
  .shipping-info-card {
    background: #F8F7F4;
    border-radius: 10px;
    padding: 24px;
  }
  .shipping-info-card h3 { font-size: 15px; font-weight: 700; color: var(--color-primary); margin: 0 0 8px; }
  .shipping-info-card p { font-size: 14px; line-height: 1.7; color: var(--color-text); margin: 0; }

  .shipping-section p { font-size: 15px; line-height: 1.8; color: var(--color-text); margin: 0 0 16px; }
  .shipping-section ul { padding-left: 20px; margin: 0 0 16px; }
  .shipping-section li { font-size: 14px; line-height: 1.8; color: var(--color-text); }

  .shipping-highlight {
    background: linear-gradient(135deg, #f9f4ec, #f0ead6);
    border: 1px solid var(--color-accent);
    border-radius: 10px;
    padding: 24px;
    text-align: center;
    margin: 24px 0;
  }
  .shipping-highlight p { font-size: 15px; font-weight: 600; color: var(--color-primary); margin: 0; }
  .shipping-highlight span { color: var(--color-accent); }

  .shipping-cta {
    text-align: center;
    margin-top: 48px;
  }
  .shipping-cta p { font-size: 15px; color: var(--color-text-light); margin: 0 0 16px; }
  .shipping-cta a { display: inline-block; padding: 14px 32px; background: var(--color-primary); color: #fff; font-size: 13px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; margin: 0 8px; }
  .shipping-cta a.btn-outline { background: transparent; border: 1px solid var(--color-primary); color: var(--color-primary); }
  @media (max-width: 600px) {
    .shipping-info-grid { grid-template-columns: 1fr; }
  }
</style>

<div class="shipping-page">
  <div class="shipping-hero">
    <h1>Shipping &amp; Returns</h1>
    <p>Fast, reliable shipping from the US. Hassle-free returns backed by our 90-day guarantee.</p>
  </div>

  <div class="shipping-section">
    <h2>Shipping</h2>
    <table class="shipping-table">
      <thead>
        <tr>
          <th>Method</th>
          <th>Delivery Time</th>
          <th>Cost</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Standard Shipping</td>
          <td>3–5 business days</td>
          <td>$4.99</td>
        </tr>
        <tr>
          <td>Subscription Orders</td>
          <td>3–5 business days</td>
          <td><strong style="color:#16a34a;">FREE</strong></td>
        </tr>
      </tbody>
    </table>
    <p class="shipping-note">Orders placed before 2:00 PM EST on business days ship the same day.</p>

    <div class="shipping-highlight">
      <p><span>Free shipping</span> on all subscription orders — no minimum, no exceptions.</p>
    </div>

    <div class="shipping-info-grid">
      <div class="shipping-info-card">
        <h3>Order Tracking</h3>
        <p>Every order includes tracking. You'll receive a confirmation email with your tracking number as soon as your order ships.</p>
      </div>
      <div class="shipping-info-card">
        <h3>Shipping Location</h3>
        <p>All orders ship from the United States. We currently ship within the US only. International shipping coming soon.</p>
      </div>
    </div>
  </div>

  <div class="shipping-section">
    <h2>Returns &amp; Refunds</h2>
    <p>Every purchase is backed by our <strong>90-day satisfaction guarantee</strong>. If you're not completely satisfied with Seven Meridian, contact us for a full refund.</p>

    <div class="shipping-info-grid">
      <div class="shipping-info-card">
        <h3>How to Request a Refund</h3>
        <p>Email support@sevenmeridian.com or use our contact form within 90 days of purchase. We'll process your refund within 3–5 business days.</p>
      </div>
      <div class="shipping-info-card">
        <h3>No Return Shipping</h3>
        <p>We don't require you to send the product back. Keep it, give it to a friend, or dispose of it — your refund processes regardless.</p>
      </div>
    </div>

    <h3 style="font-size:16px; color:var(--color-primary); margin:24px 0 12px;">Refund Policy Details</h3>
    <ul>
      <li>Refunds include the full purchase price and tax</li>
      <li>Original shipping costs are non-refundable</li>
      <li>Refunds are issued to the original payment method</li>
      <li>Allow 5–10 business days for the refund to appear on your statement</li>
      <li>One refund per customer per product</li>
      <li>Subscription orders: guarantee applies to the first delivery</li>
    </ul>
  </div>

  <div class="shipping-section">
    <h2>Damaged or Missing Orders</h2>
    <p>If your order arrives damaged or doesn't arrive at all, contact us immediately at support@sevenmeridian.com. We'll send a replacement at no cost or issue a full refund — your choice.</p>
    <p>Please include your order number and, if applicable, a photo of the damaged item so we can resolve the issue as quickly as possible.</p>
  </div>

  <div class="shipping-cta">
    <p>Have questions about your order? We're here to help.</p>
    <a href="/pages/contact">Contact Support</a>
    <a href="/pages/guarantee" class="btn-outline">90-Day Guarantee</a>
  </div>
</div>

{% schema %}
{
  "name": "Shipping & Returns Page",
  "settings": [],
  "presets": [{ "name": "Shipping & Returns Page" }]
}
{% endschema %}
