{%- comment -%}The Seven Oils infographic section{%- endcomment -%}

<style>
  .seven-oils {
    padding: 80px 24px;
    background: var(--color-background);
  }
  .seven-oils__inner {
    max-width: 1000px;
    margin: 0 auto;
  }
  .seven-oils__header {
    text-align: center;
    margin-bottom: 48px;
  }
  .seven-oils__title {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 40px);
    color: var(--color-primary);
    margin: 0 0 12px;
  }
  .seven-oils__subtitle {
    font-size: 16px;
    color: var(--color-text-light);
    max-width: 560px;
    margin: 0 auto;
  }
  .oil-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }
  .oil-card {
    background: #fff;
    padding: 28px 24px;
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }
  .oil-card__pct {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 700;
    color: var(--color-accent);
    min-width: 56px;
    line-height: 1;
  }
  .oil-card__name {
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 4px;
    font-size: 15px;
  }
  .oil-card__role {
    font-size: 13px;
    color: var(--color-text-light);
    line-height: 1.5;
  }
</style>

<section class="seven-oils">
  <div class="seven-oils__inner">
    <div class="seven-oils__header">
      <h2 class="seven-oils__title">{{ section.settings.heading }}</h2>
      <p class="seven-oils__subtitle">{{ section.settings.subheading }}</p>
    </div>
    <div class="oil-grid">
      {%- for block in section.blocks -%}
        <div class="oil-card" {{ block.shopify_attributes }}>
          <span class="oil-card__pct">{{ block.settings.percentage }}</span>
          <div>
            <div class="oil-card__name">{{ block.settings.name }}</div>
            <div class="oil-card__role">{{ block.settings.role }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Seven Oils",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Seven Oils. One Precise Blend."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Each oil selected for a specific role in the heritage formula — blended at full therapeutic concentration."
    }
  ],
  "blocks": [
    {
      "type": "oil",
      "name": "Oil",
      "settings": [
        { "type": "text", "id": "percentage", "label": "Percentage", "default": "48%" },
        { "type": "text", "id": "name", "label": "Oil name", "default": "Safflower Seed Oil" },
        { "type": "text", "id": "role", "label": "Role", "default": "Cold-pressed carrier base for smooth absorption" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Seven Oils",
      "blocks": [
        { "type": "oil", "settings": { "percentage": "48%", "name": "Safflower Seed Oil", "role": "Cold-pressed carrier base for smooth absorption" } },
        { "type": "oil", "settings": { "percentage": "22%", "name": "Menthol", "role": "Activates cooling sensation within 60 seconds" } },
        { "type": "oil", "settings": { "percentage": "10%", "name": "Eucalyptus Globulus", "role": "Crisp aromatic top note — signature heritage scent" } },
        { "type": "oil", "settings": { "percentage": "8%", "name": "Camphor", "role": "Warming follow-through that complements the menthol" } },
        { "type": "oil", "settings": { "percentage": "6%", "name": "Wintergreen", "role": "Deep warming aromatic — Gaultheria procumbens" } },
        { "type": "oil", "settings": { "percentage": "3%", "name": "Lavender", "role": "Soft floral finish, balances menthol intensity" } },
        { "type": "oil", "settings": { "percentage": "<1%", "name": "Clove Bud", "role": "Eugenol — traditional bottom note" } }
      ]
    }
  ]
}
{% endschema %}
