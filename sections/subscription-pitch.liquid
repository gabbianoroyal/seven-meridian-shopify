<style>
  .sub-pitch {
    padding: 80px 24px;
    background: var(--color-primary);
    color: #fff;
  }
  .sub-pitch__inner {
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .sub-pitch__content {}
  .sub-pitch__label {
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 12px;
  }
  .sub-pitch__title {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 40px);
    margin: 0 0 16px;
  }
  .sub-pitch__desc {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255,255,255,0.8);
    margin-bottom: 28px;
  }
  .sub-pitch__features {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
  }
  .sub-pitch__features li {
    padding: 8px 0 8px 28px;
    position: relative;
    font-size: 14px;
    color: rgba(255,255,255,0.9);
  }
  .sub-pitch__features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }
  .sub-pitch__visual {
    text-align: center;
  }
  .sub-pitch__savings {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    padding: 32px;
    text-align: center;
  }
  .sub-pitch__savings-pct {
    font-family: var(--font-heading);
    font-size: 64px;
    color: var(--color-accent);
    line-height: 1;
  }
  .sub-pitch__savings-label {
    font-size: 14px;
    margin-top: 8px;
    color: rgba(255,255,255,0.7);
  }
  @media (max-width: 768px) {
    .sub-pitch__inner { grid-template-columns: 1fr; }
  }
</style>

<section class="sub-pitch">
  <div class="sub-pitch__inner">
    <div class="sub-pitch__content">
      <p class="sub-pitch__label">{{ section.settings.label }}</p>
      <h2 class="sub-pitch__title">{{ section.settings.heading }}</h2>
      <p class="sub-pitch__desc">{{ section.settings.description }}</p>
      <ul class="sub-pitch__features">
        {%- for block in section.blocks -%}
          <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
        {%- endfor -%}
      </ul>
      <a href="{{ section.settings.button_link }}" class="btn-primary">{{ section.settings.button_text }}</a>
    </div>
    <div class="sub-pitch__visual">
      <div class="sub-pitch__savings">
        <div class="sub-pitch__savings-pct">15%</div>
        <div class="sub-pitch__savings-label">off every delivery — forever</div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Subscription Pitch",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "SUBSCRIBE & SAVE" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Never Run Out" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Get your botanical relief oil delivered on your schedule at 15% off every order. Flexible cadence, no commitment." },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Start Your Subscription" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "text", "label": "Feature text" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Subscription Pitch",
      "blocks": [
        { "type": "feature", "settings": { "text": "15% off every delivery" } },
        { "type": "feature", "settings": { "text": "Choose every 60, 75, or 90 days" } },
        { "type": "feature", "settings": { "text": "Skip, pause, or cancel anytime" } },
        { "type": "feature", "settings": { "text": "Free shipping on all subscriptions" } },
        { "type": "feature", "settings": { "text": "\"Running low\" reminder before each shipment" } }
      ]
    }
  ]
}
{% endschema %}
