<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 120" width="{{ width | default: 48 }}" height="{{ height | default: 48 }}" aria-label="Seven Meridian logo">
  {%- assign dot_color = dot_color | default: 'currentColor' -%}
  {%- assign center_color = center_color | default: '#C5A572' -%}
  <!-- Six outer dots in hexagonal arrangement -->
  <circle cx="60" cy="20" r="8" fill="{{ dot_color }}"/>
  <circle cx="94.6" cy="40" r="8" fill="{{ dot_color }}"/>
  <circle cx="94.6" cy="80" r="8" fill="{{ dot_color }}"/>
  <circle cx="60" cy="100" r="8" fill="{{ dot_color }}"/>
  <circle cx="25.4" cy="80" r="8" fill="{{ dot_color }}"/>
  <circle cx="25.4" cy="40" r="8" fill="{{ dot_color }}"/>
  <!-- Center gold anchor dot -->
  <circle cx="60" cy="60" r="10" fill="{{ center_color }}"/>
</svg>
